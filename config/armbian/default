#!/usr/bin/env bash
# Shebang for better file detection

# Smart Pi One (H3) — Armbian Bookworm server image
# These URLs are automatically overridden by the CI workflow (resolve-base-image step)
# to always use the latest SmartPi-armbian release.
DOWNLOAD_URL_IMAGE="https://github.com/Yumi-Lab/SmartPi-armbian/releases/download/v1.6.0/Yumi-smartpi1-bookworm-debian12-server-2026-03-01-2139.img.xz"
DOWNLOAD_URL_CHECKSUM="https://github.com/Yumi-Lab/SmartPi-armbian/releases/download/v1.6.0/Yumi-smartpi1-bookworm-debian12-server-2026-03-01-2139.img.xz.sha256"

# Base User
BASE_ADD_USER="yes"
BASE_USER="pi"
BASE_USER_PASSWORD="yumi"

# Needed while building for non rpi sbc
BASE_DISTRO="armbian"
BASE_IMAGE_RASPBIAN="no"

# partition resizing
BASE_ROOT_PARTITION="2"
BASE_IMAGE_ENLARGEROOT=4500
BASE_IMAGE_RESIZEROOT=600
# Set boot partition mountpoint
BASE_BOOT_MOUNT_PATH="/boot/"
# Compress not needed due compression done in workflow
BASE_RELEASE_COMPRESS=no

# Module chain for Smart Pi One (headless)
MODULES="base(udev_fix,armbian(armbian_net,clawbot,swap_setup,picoclaw,nginx_proxy,clawbot_core,telegram_bot,clawbot_wizard))"

# export Variables
export DOWNLOAD_URL_IMAGE
export DOWNLOAD_URL_CHECKSUM
export BASE_ADD_USER
export BASE_USER
export BASE_USER_PASSWORD
export BASE_DISTRO
export BASE_IMAGE_RASPBIAN
export BASE_ROOT_PARTITION
export BASE_IMAGE_ENLARGEROOT
export BASE_IMAGE_RESIZEROOT
export BASE_BOOT_MOUNT_PATH
export BASE_RELEASE_COMPRESS
export MODULES
