# shellcheck enable=require-variable-braces
set -Ee

# shellcheck disable=SC1091
source /common.sh
install_cleanup_trap

### Helper func
is_board_type() {
    local board releasefile
    board=""
    releasefile="/etc/armbian-release"
    if [[ -f "${releasefile}" ]]; then
        board="$(grep "BOARD=" "${releasefile}" | cut -d'=' -f2)"
    fi
    echo "${board}"
}

[[ -n "${BASE_USER}" ]] || BASE_USER="pi"

echo_green "Apply SmartPad specific patches..."
unpack /filesystem/root /
if [[ -f /etc/X11/xorg.conf.d/03-smartpad-rotate-touch.conf ]]; then
    rm -fv /etc/X11/xorg.conf.d/03-smartpad-rotate-touch.conf
fi
echo_green "Apply SmartPad specific patches... [DONE]"

### Enable Serial and SPI connections by default
if [[ "$(is_board_type)" == "smartpad" ]]; then
    echo_green "Enable Serial and SPI interface on SmartPad..."
    echo "overlays=spi-spidev uart1 uart2" >> "${SMARTPAD_CONFIG_TXT_FILE}"
    echo "param_spidev_spi_bus=1" >> "${SMARTPAD_CONFIG_TXT_FILE}"
    echo_green "Enable Serial and SPI interface on SmartPad... DONE!"
fi

### Install Plymouth theme from Yumi Lab repo
echo_green "Install Yumi Lab Plymouth theme on SmartPad..."

smartpad_install_theme() {
    local src dest
    dest="/usr/share/plymouth/themes/"
    src="/home/${BASE_USER}/$(basename "${SMARTPAD_PLYMOUTH_REPO/.git/}")"
    src="${src}/pack_2/hexagon_alt"
    if [[ -d "${src}" ]]; then
        sudo cp -vr "${src}" "${dest}"
    fi
    echo_green "Set default theme to ${SMARTPAD_PLYMOUTH_THEME} ..."
    sudo plymouth-set-default-theme "${SMARTPAD_PLYMOUTH_THEME}" || true
}

pushd "/home/${BASE_USER}" &>/dev/null || exit 1
sudo -u "${BASE_USER}" git clone "${SMARTPAD_PLYMOUTH_REPO}" || true
smartpad_install_theme
popd &>/dev/null || exit 1

### Run initramfs update at build time (was deferred to dead firstboot.service)
echo_green "Updating initramfs for Plymouth theme..."
update-initramfs -u 2>/dev/null || true
echo_green "Updating initramfs ... [DONE]"

### Enable bootlogo at build time
if [[ -f "${SMARTPAD_CONFIG_TXT_FILE}" ]]; then
    echo_green "Enable boot logo in ${SMARTPAD_CONFIG_TXT_FILE}..."
    sed -i 's/bootlogo=false/bootlogo=true/' "${SMARTPAD_CONFIG_TXT_FILE}" 2>/dev/null || true
fi

### Framebuffer rotation (180°) + touchscreen calibration already in udev rule
echo_green "Setting framebuffer rotation 180° for SmartPad display..."
if [[ -f "${SMARTPAD_CONFIG_TXT_FILE}" ]]; then
    # Add fbcon rotation if not already set
    if ! grep -q "extraargs=" "${SMARTPAD_CONFIG_TXT_FILE}"; then
        echo "extraargs=fbcon=rotate:2" >> "${SMARTPAD_CONFIG_TXT_FILE}"
    else
        sed -i '/extraargs=/s/$/ fbcon=rotate:2/' "${SMARTPAD_CONFIG_TXT_FILE}"
    fi
fi

echo_green "Install Yumi Lab Plymouth theme on SmartPad... [DONE]"
### Fix SSH on Trixie: disable ssh.socket (socket-activation) to prevent
### conflict with ssh.service on second boot (Debian 13 default changed to
### socket activation but Armbian still enables ssh.service — both conflict)
echo_green "Fixing SSH service activation on Trixie..."
systemctl_if_exists disable ssh.socket || true
systemctl_if_exists enable ssh.service || true
# Regenerate host keys at build time so they exist in the image
if [[ ! -f /etc/ssh/ssh_host_ed25519_key ]]; then
    dpkg-reconfigure -f noninteractive openssh-server 2>/dev/null || \
    ssh-keygen -A 2>/dev/null || true
fi
echo_green "SSH fix applied."

echo_green "SmartPad module ... DONE!"
