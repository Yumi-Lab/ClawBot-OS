#!/usr/bin/env bash
#### ClawbotOS SmartPad firstboot actions
####
#### Based on work of Stephan Wendel aka KwadFan
#### Modified for ClawbotOS by Yumi Lab
####
#### This File is distributed under GPLv3
####

set -e

DIALOGRC=/.firstboot
export DIALOGRC
DIALOG="$(command -v dialog)"
DIALOG=("${DIALOG}" --backtitle "ClawbotOS for SmartPad")
RESOLUTION=(20 60)

# Change active tty
chvt 2 2>/dev/null || true

welcome_msg() {
    cat << EOF

Hello dear YUMI SmartPad user,
Please be patient, we have to prepare your first start!

    *** DO NOT UNPLUG DEVICE OR DISRUPT THIS PROCESS! ***

Some steps may take several minutes. Stay patient please.
The device will reboot after exiting ...
Continuing setup in ...
EOF
}

reboot_msg() {
    cat << EOF

Your device will be restarted in 5 seconds...

Thank you for being patient and have fun with your
    *** ClawbotOS SmartPad ***

Access your AI dashboard at:
    http://clawbot.local

EOF
}

gen_initramfs() {
    update-initramfs -u &>/dev/null
}

disable_firstboot() {
    systemctl --quiet disable firstboot.service &>/dev/null || true
    rm -f /etc/systemd/system/firstboot.service &>/dev/null || true
}

# Set larger font for touchscreen readability
setfont /usr/share/consolefonts/Lat15-TerminusBold20x10.psf.gz 2>/dev/null || true

# Welcome msg
"${DIALOG[@]}" --clear --title "SmartPad First Boot" \
    --no-cancel --no-ok --pause "$(welcome_msg)" "${RESOLUTION[@]}" 15

# Init gauge - enable bootlogo
sleep 1 | "${DIALOG[@]}" --clear --gauge "SmartPad preparation ..." "${RESOLUTION[@]}" 0
if [[ -f /boot/armbianEnv.txt ]]; then
    sed -i 's/bootlogo=false/bootlogo=true/' /boot/armbianEnv.txt |
    "${DIALOG[@]}" --clear --gauge "Enable boot logo ..." "${RESOLUTION[@]}" 10
fi

# Update initramfs for Plymouth theme
gen_initramfs | "${DIALOG[@]}" --clear --gauge "Generate Initial RAM filesystem ..." "${RESOLUTION[@]}" 40

# Disable firstboot service
disable_firstboot | "${DIALOG[@]}" --clear --gauge "Disable firstboot service ..." "${RESOLUTION[@]}" 80

# Show fake finish
sleep 2 | "${DIALOG[@]}" --clear --gauge "Finalize SmartPad setup ..." "${RESOLUTION[@]}" 100

# Show reboot screen
"${DIALOG[@]}" --clear --title "SmartPad Setup Complete" \
    --no-cancel --no-ok --pause "$(reboot_msg)" "${RESOLUTION[@]}" 5

# Cleanup
rm -f /.firstboot

# Reboot
reboot

exit 0
