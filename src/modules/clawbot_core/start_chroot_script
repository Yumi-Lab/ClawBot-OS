#!/usr/bin/env bash
# shellcheck enable=require-variable-braces
set -Ee

source /common.sh
install_cleanup_trap

echo_green "Installing ClawbotCore ..."

## Step 1: Install dependencies
apt-get update --allow-releaseinfo-change
check_install_pkgs ${CLAWBOT_CORE_DEPS} qrencode
## END Step 1

## Step 2+3: Clone repo directly into /usr/local/lib/clawbot-core (preserves .git for OTA updates)
echo_green "Cloning ClawbotCore from ${CLAWBOT_CORE_REPO} ..."
git clone --branch "${CLAWBOT_CORE_BRANCH}" \
    "${CLAWBOT_CORE_REPO}" /usr/local/lib/clawbot-core
chmod +x /usr/local/lib/clawbot-core/clawbot_core/main.py
## END Step 2+3

## Step 4: Create modules directory for pi user
mkdir -p /home/pi/.clawbot/modules
chown -R pi:pi /home/pi/.clawbot
## END Step 4

## Step 5: Install Python websockets for cloud WebSocket client
echo_green "Installing Python websockets package ..."
pip3 install --no-cache-dir --break-system-packages websockets
## END Step 5

## Step 6: Install systemd services and scripts
echo_green "Installing systemd units and scripts ..."
unpack /filesystem/root /
chmod +x /usr/local/bin/clawbot-provision
chmod +x /usr/local/bin/clawbot-cloud
mkdir -p /etc/clawbot/conf.d
systemctl_if_exists enable clawbot-core.service
systemctl_if_exists enable clawbot-cloud.service
## END Step 6

echo_green "Installing ClawbotCore ... DONE!"
