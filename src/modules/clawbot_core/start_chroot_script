#!/usr/bin/env bash
# shellcheck enable=require-variable-braces
set -Ee

source /common.sh
install_cleanup_trap

echo_green "Installing ClawbotCore ..."

## Step 1: Install dependencies
apt-get update --allow-releaseinfo-change
check_install_pkgs ${CLAWBOT_CORE_DEPS} qrencode
## END Step 1

## Step 2+3: Clone repo directly into /usr/local/lib/clawbot-core (preserves .git for OTA updates)
echo_green "Cloning ClawbotCore from ${CLAWBOT_CORE_REPO} ..."
git clone --branch "${CLAWBOT_CORE_BRANCH}" \
    "${CLAWBOT_CORE_REPO}" /usr/local/lib/clawbot-core
chmod +x /usr/local/lib/clawbot-core/clawbot_core/main.py
## END Step 2+3

## Step 4: Create modules directory for pi user
mkdir -p /home/pi/.clawbot/modules
chown -R pi:pi /home/pi/.clawbot
## END Step 4

## Step 5: Install Python websockets for cloud WebSocket client
echo_green "Installing Python websockets package ..."
pip3 install --no-cache-dir --break-system-packages websockets
## END Step 5

## Step 5b: Install Google Drive connector dependencies
echo_green "Installing Google Drive connector dependencies ..."
pip3 install --no-cache-dir --break-system-packages google-api-python-client google-auth-oauthlib
## END Step 5b

## Step 6: Install systemd services and scripts
echo_green "Installing systemd units and scripts ..."
unpack /filesystem/root /
chmod +x /usr/local/bin/clawbot-provision
chmod +x /usr/local/bin/clawbot-cloud
mkdir -p /etc/clawbot/conf.d
systemctl_if_exists enable clawbot-core.service
systemctl_if_exists enable clawbot-cloud.service
## END Step 6

## Step 7: Install Node.js 18+ for WhatsApp bridge (armv7 compatible)
echo_green "Checking Node.js for WhatsApp bridge ..."
NODE_MAJOR=18
if ! command -v node &>/dev/null || [ "$(node -e 'process.exit(parseInt(process.version.slice(1)) < 18 ? 1 : 0)' 2>/dev/null; echo $?)" = "1" ]; then
    echo_green "Installing Node.js ${NODE_MAJOR} from NodeSource ..."
    curl -fsSL "https://deb.nodesource.com/setup_${NODE_MAJOR}.x" | bash -
    apt-get install -y nodejs
else
    echo_green "Node.js $(node --version) already installed"
fi
## END Step 7

## Step 7b: Install whatsapp-bridge npm dependencies
BRIDGE_DIR="/usr/local/lib/clawbot-core/modules/whatsapp-bridge"
if [ -f "${BRIDGE_DIR}/package.json" ]; then
    echo_green "Installing whatsapp-bridge npm dependencies ..."
    cd "${BRIDGE_DIR}"
    npm install --production --no-fund --no-audit
    mkdir -p /home/pi/.clawbot/wa-auth
    chown -R pi:pi /home/pi/.clawbot/wa-auth
    cd /
else
    echo_green "whatsapp-bridge not found in repo — skipping npm install"
fi
## END Step 7b

## Step 7c: Install whatsapp-bridge systemd service (disabled by default)
echo_green "Installing whatsapp-bridge.service (disabled by default) ..."
cat > /etc/systemd/system/whatsapp-bridge.service << 'SVCEOF'
[Unit]
Description=WhatsApp Baileys Bridge for ClawbotCore
After=network.target clawbot-core.service
Wants=clawbot-core.service

[Service]
Type=simple
User=pi
WorkingDirectory=/usr/local/lib/clawbot-core/modules/whatsapp-bridge
Environment=AUTH_DIR=/home/pi/.clawbot/wa-auth
Environment=CORE_URL=http://127.0.0.1:8090
ExecStart=/usr/bin/node /usr/local/lib/clawbot-core/modules/whatsapp-bridge/bridge.js
Restart=always
RestartSec=3
StandardOutput=journal
StandardError=journal
SyslogIdentifier=whatsapp-bridge

[Install]
WantedBy=multi-user.target
SVCEOF
systemctl daemon-reload
# NOT enabling by default — user activates via Services panel in dashboard
## END Step 7c

echo_green "Installing ClawbotCore ... DONE!"
