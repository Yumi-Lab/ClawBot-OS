#!/usr/bin/env bash
#### clawbot-heartbeat — ClawbotOS Cloud Heartbeat
####
#### Sends periodic heartbeat to Clawbot Cloud with device telemetry.
#### If the cloud responds with a provision command, calls clawbot-provision.
####
#### Written by Yumi Lab — BUSL-1.1

set -euo pipefail

CLOUD_API="https://clawbot-api.yumi-lab.com/v1"
DEVICE_ID_FILE="/etc/clawbot/device-id"
BOARD_FILE="/etc/clawbot/board"
PROVISION_BIN="/usr/local/bin/clawbot-provision"
LOG_TAG="clawbot-heartbeat"

log()  { logger -t "${LOG_TAG}" -- "$*"; }
info() { log "INFO  $*"; }
err()  { log "ERROR $*"; echo "[heartbeat] ERROR: $*" >&2; }

get_device_id() {
    if [[ -f "${DEVICE_ID_FILE}" ]]; then
        cat "${DEVICE_ID_FILE}"
    else
        "${PROVISION_BIN}" --device-id
    fi
}

get_board() {
    [[ -f "${BOARD_FILE}" ]] && cat "${BOARD_FILE}" && return
    grep -m1 "BOARD=" /etc/armbian-release 2>/dev/null | cut -d= -f2 | tr -d '"' || echo "unknown"
}

get_firmware() {
    grep -m1 "VERSION=" /etc/clawbot-release 2>/dev/null | cut -d= -f2 | tr -d '"' || echo "0.0.0"
}

get_ip() {
    # Prefer eth0, fall back to wlan0, then any routed interface
    ip route get 1.1.1.1 2>/dev/null | grep -oP 'src \K\S+' | head -1 || echo "unknown"
}

service_active() {
    systemctl is-active --quiet "$1" 2>/dev/null && echo "active" || echo "inactive"
}

send_heartbeat() {
    local device_id board firmware ip_addr picoclaw_status core_status
    device_id=$(get_device_id)
    board=$(get_board)
    firmware=$(get_firmware)
    ip_addr=$(get_ip)
    picoclaw_status=$(service_active picoclaw.service)
    core_status=$(service_active clawbot-core.service)

    local payload
    payload=$(printf '{"device_id":"%s","board":"%s","firmware":"%s","ip":"%s","services":{"picoclaw":"%s","clawbot_core":"%s"}}' \
        "${device_id}" "${board}" "${firmware}" "${ip_addr}" "${picoclaw_status}" "${core_status}")

    info "Sending heartbeat (device=${device_id}, board=${board}, fw=${firmware})"

    local resp http_code body
    resp=$(curl -sf --max-time 10 \
        -X POST "${CLOUD_API}/heartbeat" \
        -H "Content-Type: application/json" \
        -d "${payload}" \
        -w "\n%{http_code}" 2>/dev/null) || { err "Heartbeat failed (network unreachable)"; return 0; }

    http_code=$(echo "${resp}" | tail -1)
    body=$(echo "${resp}" | head -n -1)

    if [[ "${http_code}" != "200" ]]; then
        err "Heartbeat HTTP ${http_code}"
        return 0
    fi

    info "Heartbeat OK"

    # Check if cloud wants us to provision
    local should_provision
    should_provision=$(echo "${body}" | python3 -c \
        "import sys,json; d=json.load(sys.stdin); print(d.get('provision', False))" \
        2>/dev/null || echo "False")

    if [[ "${should_provision}" == "True" || "${should_provision}" == "true" ]]; then
        info "Cloud requests provisioning — calling clawbot-provision"
        "${PROVISION_BIN}" || err "Provision failed"
    fi
}

send_heartbeat
