# shellcheck enable=require-variable-braces
set -Ee

if [[ "${DEBIAN_FRONTEND}" != "noninteractive" ]]; then
    export DEBIAN_FRONTEND=noninteractive
fi

# shellcheck disable=SC1091
source /common.sh
install_cleanup_trap

## Step 1: Create ClawbotOS release file
echo_green "Creating ClawbotOS release file ..."

function get_parent {
    grep VERSION_CODENAME /etc/os-release | cut -d '=' -f2
}

echo "${DIST_NAME} release ${DIST_VERSION} ($(get_parent))" > /etc/"${DIST_NAME,,}"-release
## END Step 1

## Step 2: Symlink for distro detection (Moonraker/agent compatibility)
if [[ -f "/etc/armbian-release" ]]; then
    echo_green "Apply release file workaround (armbian based image) ..."
    ln -sf /etc/"${DIST_NAME,,}"-release /etc/aaaa-release
fi
## END Step 2

## Step 3: Install ClawbotOS dependencies
echo_green "Installing ClawbotOS utility packages ..."
apt-get update --allow-releaseinfo-change
# shellcheck disable=SC2086
check_install_pkgs ${CLAWBOT_DEPS}
## END Step 3

## Step 3b: Install clawbot-status-api, updater and enable service
echo_green "Installing ClawbotOS status API and dashboard updater ..."
unpack /filesystem/root /
chmod +x /usr/local/bin/clawbot-status-api
chmod +x /usr/local/bin/clawbot-update-dashboard
systemctl_if_exists enable clawbot-status-api.service
## END Step 3b

## Step 4: Set hostname to clawbot
echo_green "Setting hostname to 'clawbot' ..."
echo "clawbot" > /etc/hostname
sed -i 's/127.0.1.1.*/127.0.1.1\tclawbot/' /etc/hosts
## END Step 4

## Step 5: Configure avahi for mDNS (clawbot.local)
echo_green "Configuring mDNS (clawbot.local) ..."
if [[ -f /etc/avahi/avahi-daemon.conf ]]; then
    sed -i 's/#host-name=.*/host-name=clawbot/' /etc/avahi/avahi-daemon.conf
fi
## END Step 5

## Step 6: Install service status helper
echo_green "Installing clawbot-status utility ..."
cat > /usr/local/bin/clawbot-status << 'STATUS_EOF'
#!/usr/bin/env bash
# ClawbotOS - Show service status
echo "=== ClawbotOS Service Status ==="
echo "PicoClaw:  $(systemctl is-active picoclaw.service 2>/dev/null || echo 'not installed')"
echo "nginx:     $(systemctl is-active nginx.service 2>/dev/null || echo 'not installed')"
echo "Telegram:  $(systemctl is-active clawbot-telegram.service 2>/dev/null || echo 'not installed')"
STATUS_EOF
chmod +x /usr/local/bin/clawbot-status
## END Step 6

echo_green "ClawbotOS branding applied."
