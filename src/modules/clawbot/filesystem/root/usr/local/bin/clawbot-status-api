#!/usr/bin/env python3
"""
ClawbotOS System Status API
Lightweight HTTP server on 127.0.0.1:8089
Provides real system metrics to the dashboard.
"""

import json
import os
import socket
import subprocess
import time
from http.server import BaseHTTPRequestHandler, HTTPServer

PORT = 8089
PICOCLAW_CONFIG = "/home/pi/.picoclaw/config.json"

# Whitelist of files that can be read/written via the API
ALLOWED_FILES = {
    "/home/pi/.picoclaw/config.json",
    "/home/pi/.clawbot-telegram.env",
    "/etc/nginx/sites-available/clawbot",
    "/etc/nginx/nginx.conf",
    "/etc/systemd/system/picoclaw.service",
    "/etc/systemd/system/clawbot-telegram.service",
}

# Whitelist of services for log streaming
ALLOWED_LOG_SERVICES = {
    "picoclaw", "nginx", "clawbot-telegram",
    "clawbot-status-api", "clawbot-swap",
}


def _read_proc(path):
    try:
        with open(path) as f:
            return f.read().strip()
    except Exception:
        return ""


def get_cpu_percent():
    """Measure CPU usage over a 200ms interval."""
    def read_stat():
        line = _read_proc("/proc/stat").splitlines()[0].split()[1:]
        nums = list(map(int, line))
        total = sum(nums)
        idle = nums[3]
        return total, idle

    t1, i1 = read_stat()
    time.sleep(0.2)
    t2, i2 = read_stat()
    diff_total = t2 - t1
    diff_idle = i2 - i1
    if diff_total == 0:
        return 0
    return round(100 * (1 - diff_idle / diff_total))


def get_ram_percent():
    mem = {}
    for line in _read_proc("/proc/meminfo").splitlines():
        parts = line.split(":")
        if len(parts) == 2:
            key = parts[0].strip()
            val = parts[1].strip().split()[0]
            mem[key] = int(val)
    total = mem.get("MemTotal", 0)
    available = mem.get("MemAvailable", mem.get("MemFree", 0))
    swap_total = mem.get("SwapTotal", 0)
    if total == 0:
        return 0, 0, 0
    used = total - available
    ram_pct = round(100 * used / total)
    return ram_pct, total // 1024, swap_total // 1024


def get_disk_percent():
    try:
        result = subprocess.run(
            ["df", "-B1", "/"],
            capture_output=True, text=True, timeout=3
        )
        lines = result.stdout.strip().splitlines()
        if len(lines) > 1:
            parts = lines[1].split()
            used = int(parts[2])
            size = int(parts[1])
            return round(100 * used / size) if size else 0
    except Exception:
        pass
    return 0


def get_temp():
    for path in [
        "/sys/class/thermal/thermal_zone0/temp",
        "/sys/devices/virtual/thermal/thermal_zone0/temp",
    ]:
        raw = _read_proc(path)
        if raw:
            try:
                return round(int(raw) / 1000)
            except ValueError:
                pass
    return None


def get_uptime():
    raw = _read_proc("/proc/uptime")
    if raw:
        try:
            return int(float(raw.split()[0]))
        except ValueError:
            pass
    return 0


def get_ip():
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.connect(("8.8.8.8", 80))
        ip = s.getsockname()[0]
        s.close()
        return ip
    except Exception:
        return "127.0.0.1"


def get_network():
    eth = False
    wifi_ssid = None
    try:
        result = subprocess.run(
            ["ip", "-brief", "addr"],
            capture_output=True, text=True, timeout=3
        )
        for line in result.stdout.splitlines():
            if line.startswith("eth0") and "UP" in line:
                eth = True
            if line.startswith("wlan0") and "UP" in line:
                eth_info = line.split()
                eth = True
    except Exception:
        pass

    try:
        result = subprocess.run(
            ["iwgetid", "-r"],
            capture_output=True, text=True, timeout=3
        )
        ssid = result.stdout.strip()
        if ssid:
            wifi_ssid = ssid
    except Exception:
        pass

    return eth, wifi_ssid


def get_services():
    services = {}
    for svc in ["picoclaw", "nginx", "clawbot-telegram"]:
        try:
            r = subprocess.run(
                ["systemctl", "is-active", f"{svc}.service"],
                capture_output=True, text=True, timeout=3
            )
            services[svc] = r.stdout.strip() == "active"
        except Exception:
            services[svc] = False
    return services


def get_stats():
    cpu = get_cpu_percent()
    ram_pct, ram_total_mb, swap_mb = get_ram_percent()
    disk = get_disk_percent()
    temp = get_temp()
    uptime = get_uptime()
    ip = get_ip()
    hostname = socket.gethostname()
    eth_connected, wifi_ssid = get_network()
    services = get_services()

    return {
        "cpu": cpu,
        "ram": ram_pct,
        "ram_total_mb": ram_total_mb,
        "disk": disk,
        "temp": temp,
        "uptime": uptime,
        "ip": ip,
        "hostname": hostname,
        "eth_connected": eth_connected,
        "wifi_ssid": wifi_ssid,
        "swap_mb": swap_mb,
        "services": services,
    }


def update_picoclaw_config(provider, model, api_key, base_url):
    """Update PicoClaw config.json and restart the service."""
    PROVIDER_BASE_URLS = {
        "openai":     "https://api.openai.com/v1",
        "anthropic":  "https://api.anthropic.com/v1",
        "openrouter": "https://openrouter.ai/api/v1",
        "deepseek":   "https://api.deepseek.com/v1",
    }

    if not base_url and provider in PROVIDER_BASE_URLS:
        base_url = PROVIDER_BASE_URLS[provider]

    config = {
        "gateway": {"host": "0.0.0.0", "port": 8080},
        "agents": {
            "defaults": {
                "model": "default",
                "workspace": "~/.picoclaw/workspace",
                "max_tokens": 4096,
                "temperature": 0.7
            }
        },
        "model_list": [
            {
                "model_name": "default",
                "model": model,
                "api_key": api_key,
                "base_url": base_url,
                "request_timeout": 120
            }
        ],
        # maixcam satisfies picoclaw v0.2.0 requirement of ≥1 enabled channel
        "channels": {
            "maixcam": {
                "enabled": True,
                "host": "127.0.0.1",
                "port": 18790,
                "allow_from": [],
                "reasoning_channel_id": ""
            }
        },
        "tools": {"web": {"duckduckgo": {"enabled": True, "max_results": 5}}},
        "log_level": "info"
    }

    config_dir = os.path.dirname(PICOCLAW_CONFIG)
    os.makedirs(config_dir, exist_ok=True)

    with open(PICOCLAW_CONFIG, "w") as f:
        json.dump(config, f, indent=2)

    os.chmod(PICOCLAW_CONFIG, 0o600)
    try:
        subprocess.run(["chown", "pi:pi", PICOCLAW_CONFIG], timeout=3)
        subprocess.run(
            ["systemctl", "restart", "picoclaw.service"],
            timeout=10
        )
    except Exception:
        pass


def service_action(service, action):
    if action not in ("start", "stop", "restart"):
        return False
    if service not in ("picoclaw", "nginx", "clawbot-telegram"):
        return False
    try:
        subprocess.run(
            ["systemctl", action, f"{service}.service"],
            timeout=15
        )
        return True
    except Exception:
        return False


def read_file(path):
    """Read file content if path is whitelisted."""
    if path not in ALLOWED_FILES:
        return None, "forbidden"
    try:
        with open(path) as f:
            return f.read(), None
    except FileNotFoundError:
        return "", None  # Return empty string for missing files
    except Exception as e:
        return None, str(e)


def write_file(path, content):
    """Write file content if path is whitelisted."""
    if path not in ALLOWED_FILES:
        return False, "forbidden"
    try:
        os.makedirs(os.path.dirname(path), exist_ok=True)
        with open(path, "w") as f:
            f.write(content)
        # Restrict permissions for credential files
        if path.endswith((".json", ".env")):
            os.chmod(path, 0o600)
            try:
                subprocess.run(["chown", "pi:pi", path], timeout=3)
            except Exception:
                pass
        return True, None
    except Exception as e:
        return False, str(e)


CLAWBOT_CORE_REPO = "https://github.com/Yumi-Lab/clawbot-core"
CLAWBOT_CORE_BRANCH = "main"
CLAWBOT_CORE_INSTALL_DIR = "/usr/local/lib/clawbot-core"
CLAWBOT_CORE_VERSION_FILE = "/usr/local/lib/clawbot-core/VERSION"


def get_clawbot_core_version() -> str:
    """Read local ClawbotCore version from VERSION file or git."""
    try:
        with open(CLAWBOT_CORE_VERSION_FILE) as f:
            return f.read().strip()
    except Exception:
        return "unknown"


def update_clawbot_core() -> dict:
    """Pull latest ClawbotCore from GitHub, install, restart service."""
    import tempfile
    import shutil

    local_ver = get_clawbot_core_version()
    try:
        tmp = tempfile.mkdtemp(prefix="clawbot-core-update-")
        subprocess.run(
            ["git", "clone", "--depth=1", "--branch", CLAWBOT_CORE_BRANCH,
             CLAWBOT_CORE_REPO, tmp],
            check=True, capture_output=True, timeout=60
        )
        # Install core files
        src_core = os.path.join(tmp, "clawbot_core")
        src_store = os.path.join(tmp, "store")
        if os.path.isdir(src_core):
            for f in os.listdir(src_core):
                shutil.copy2(os.path.join(src_core, f), CLAWBOT_CORE_INSTALL_DIR)
        if os.path.isdir(src_store):
            dest_store = os.path.join(CLAWBOT_CORE_INSTALL_DIR, "store")
            if os.path.isdir(dest_store):
                shutil.rmtree(dest_store)
            shutil.copytree(src_store, dest_store)
        shutil.rmtree(tmp, ignore_errors=True)

        # Restart service
        subprocess.run(["systemctl", "restart", "clawbot-core.service"],
                       timeout=10, capture_output=True)

        new_ver = get_clawbot_core_version()
        return {"updated": True, "from": local_ver, "to": new_ver}
    except subprocess.CalledProcessError as e:
        return {"updated": False, "error": e.stderr.decode(errors="replace")[:300]}
    except Exception as e:
        return {"updated": False, "error": str(e)}


def update_dashboard(check_only=False):
    """Run clawbot-update-dashboard and return parsed JSON result."""
    cmd = ["/usr/local/bin/clawbot-update-dashboard"]
    if check_only:
        cmd.append("--check")
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=40)
        output = result.stdout.strip()
        return json.loads(output) if output else {"error": result.stderr.strip()}
    except subprocess.TimeoutExpired:
        return {"error": "timeout"}
    except Exception as e:
        return {"error": str(e)}


def get_logs(service, lines=100):
    """Get recent logs for a service via journalctl."""
    if service not in ALLOWED_LOG_SERVICES:
        return None, "forbidden"
    try:
        lines = min(max(int(lines), 1), 500)
        result = subprocess.run(
            ["journalctl", "-u", f"{service}.service", "-n", str(lines),
             "--no-pager", "--output=short-iso"],
            capture_output=True, text=True, timeout=5
        )
        return result.stdout, None
    except Exception as e:
        return None, str(e)


class Handler(BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        pass  # silence access logs

    def send_json(self, code, data):
        body = json.dumps(data).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Access-Control-Allow-Origin", "*")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_OPTIONS(self):
        self.send_response(200)
        self.send_header("Access-Control-Allow-Origin", "*")
        self.send_header("Access-Control-Allow-Methods", "GET, POST, OPTIONS")
        self.send_header("Access-Control-Allow-Headers", "Content-Type")
        self.end_headers()

    def do_GET(self):
        from urllib.parse import urlparse, parse_qs, unquote

        parsed = urlparse(self.path)
        qs = parse_qs(parsed.query)

        if parsed.path == "/stats":
            try:
                self.send_json(200, get_stats())
            except Exception as e:
                self.send_json(500, {"error": str(e)})

        elif parsed.path == "/file":
            path = unquote(qs.get("path", [""])[0])
            if not path:
                self.send_json(400, {"error": "missing path"})
                return
            content, err = read_file(path)
            if err:
                code = 403 if err == "forbidden" else 500
                self.send_json(code, {"error": err})
            else:
                self.send_json(200, {"path": path, "content": content})

        elif parsed.path == "/dashboard-version":
            result = update_dashboard(check_only=True)
            self.send_json(200, result)

        elif parsed.path == "/core-version":
            self.send_json(200, {"version": get_clawbot_core_version()})

        elif parsed.path == "/logs":
            service = qs.get("service", [""])[0]
            lines = qs.get("lines", ["100"])[0]
            if not service:
                self.send_json(400, {"error": "missing service"})
                return
            content, err = get_logs(service, lines)
            if err:
                code = 403 if err == "forbidden" else 500
                self.send_json(code, {"error": err})
            else:
                self.send_json(200, {"service": service, "logs": content})

        else:
            self.send_json(404, {"error": "not found"})

    def do_POST(self):
        length = int(self.headers.get("Content-Length", 0))
        body = self.rfile.read(length)

        try:
            data = json.loads(body) if body else {}
        except json.JSONDecodeError:
            self.send_json(400, {"error": "invalid JSON"})
            return

        from urllib.parse import urlparse
        path = urlparse(self.path).path

        if path == "/file":
            file_path = data.get("path", "")
            content = data.get("content", "")
            if not file_path:
                self.send_json(400, {"error": "missing path"})
                return
            ok, err = write_file(file_path, content)
            if err:
                code = 403 if err == "forbidden" else 500
                self.send_json(code, {"error": err})
            else:
                self.send_json(200, {"ok": True})
            return

        elif path == "/config":
            try:
                update_picoclaw_config(
                    provider=data.get("provider", "openai"),
                    model=data.get("model", "gpt-4o"),
                    api_key=data.get("api_key", ""),
                    base_url=data.get("base_url", "")
                )
                self.send_json(200, {"ok": True})
            except Exception as e:
                self.send_json(500, {"error": str(e)})

        elif path == "/update-dashboard":
            result = update_dashboard(check_only=False)
            self.send_json(200, result)
            return

        elif path == "/update-core":
            result = update_clawbot_core()
            self.send_json(200, result)
            return

        elif path == "/service":
            svc = data.get("service", "")
            action = data.get("action", "")
            ok = service_action(svc, action)
            self.send_json(200 if ok else 400, {"ok": ok})

        else:
            self.send_json(404, {"error": "not found"})


if __name__ == "__main__":
    server = HTTPServer(("127.0.0.1", PORT), Handler)
    server.serve_forever()
