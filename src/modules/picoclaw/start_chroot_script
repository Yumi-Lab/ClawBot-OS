#!/usr/bin/env bash
#### PicoClaw install module
####
#### https://github.com/sipeed/picoclaw
#### This File is distributed under GPLv3
####

# shellcheck enable=require-variable-braces
set -Ee

# shellcheck disable=SC1091
source /common.sh
install_cleanup_trap

echo_green "Installing PicoClaw ..."

## Step 1: Install dependencies
apt-get update --allow-releaseinfo-change
# shellcheck disable=SC2086
check_install_pkgs ${PICOCLAW_DEPS}
## END Step 1

## Step 2: Create config directory
pushd "/home/${BASE_USER}" &> /dev/null || exit 1
mkdir -p "/home/${BASE_USER}/.picoclaw"
## END Step 2

## Step 3: Download precompiled ARM binary (tar.gz)
echo_green "Downloading PicoClaw ${PICOCLAW_VERSION} precompiled binary ..."
PICOCLAW_DL_URL="${PICOCLAW_RELEASE_URL}/${PICOCLAW_TARBALL}"

if curl -fsSL -o "/tmp/${PICOCLAW_TARBALL}" "${PICOCLAW_DL_URL}"; then
    echo_green "Extracting PicoClaw binary ..."
    tar -xzf "/tmp/${PICOCLAW_TARBALL}" -C /tmp/
    # Find and install the binary
    find /tmp/ -name "picoclaw" -type f -executable -exec cp {} /usr/local/bin/picoclaw \; 2>/dev/null \
        || cp /tmp/picoclaw /usr/local/bin/picoclaw 2>/dev/null \
        || { echo_green "Extracting from tar root ..."; tar -xzf "/tmp/${PICOCLAW_TARBALL}" -C /usr/local/bin/ picoclaw 2>/dev/null || true; }
    chmod +x /usr/local/bin/picoclaw
    rm -f "/tmp/${PICOCLAW_TARBALL}"
    echo_green "PicoClaw binary installed successfully."
else
    ## Step 3b: Fallback -- build from source with recent Go
    echo_green "Binary download failed, building from source ..."
    echo_green "Installing Go ${PICOCLAW_GO_VERSION} from golang.org ..."
    GO_TARBALL="go${PICOCLAW_GO_VERSION}.linux-armv6l.tar.gz"
    curl -fsSL -o "/tmp/${GO_TARBALL}" "https://go.dev/dl/${GO_TARBALL}"
    tar -C /usr/local -xzf "/tmp/${GO_TARBALL}"
    rm -f "/tmp/${GO_TARBALL}"
    export PATH="/usr/local/go/bin:${PATH}"

    sudo -u "${BASE_USER}" git clone --depth 1 -b "${PICOCLAW_REPO_BRANCH}" \
        "${PICOCLAW_REPO}" "/home/${BASE_USER}/picoclaw-src"
    pushd "/home/${BASE_USER}/picoclaw-src" &> /dev/null || exit 1
    /usr/local/go/bin/go build -o /usr/local/bin/picoclaw .
    popd &> /dev/null || exit 1
    rm -rf "/home/${BASE_USER}/picoclaw-src"
    # Remove Go toolchain to save disk space (~500MB)
    rm -rf /usr/local/go
fi
## END Step 3

## Step 4: Install default config template
echo_green "Installing PicoClaw default configuration ..."
unpack /filesystem/root /
unpack /filesystem/home /home
## END Step 4

## Step 5: Set correct ownership
chown -R "${BASE_USER}:${BASE_USER}" "/home/${BASE_USER}/.picoclaw"
## END Step 5

## Step 6: Enable systemd service
echo_green "Enabling picoclaw.service ..."
systemctl_if_exists enable picoclaw.service
## END Step 6

popd &> /dev/null || exit 1

echo_green "Installing PicoClaw ... DONE!"
