#!/usr/bin/env python3
"""
ClawbotOS Telegram Bot
Bridges Telegram messages to PicoClaw.
Config: /home/pi/.clawbot-telegram.env
  TELEGRAM_TOKEN=<bot_token>
  ALLOWED_USERS=<comma-separated chat IDs, empty = allow all>
  AGENT_URL=http://127.0.0.1:8080  (optional override)
"""

import json
import logging
import os
import sys
import time
import urllib.error
import urllib.request

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s",
    handlers=[logging.StreamHandler(sys.stdout)],
)
log = logging.getLogger(__name__)

ENV_FILE = "/home/pi/.clawbot-telegram.env"

AGENT_URL_DEFAULT = "http://127.0.0.1:8080"


def load_env():
    env = {}
    try:
        with open(ENV_FILE) as f:
            for line in f:
                line = line.strip()
                if line and not line.startswith("#") and "=" in line:
                    k, _, v = line.partition("=")
                    env[k.strip()] = v.strip()
    except FileNotFoundError:
        pass
    return env


def tg_request(token, method, params=None):
    url = f"https://api.telegram.org/bot{token}/{method}"
    data = json.dumps(params or {}).encode()
    req = urllib.request.Request(
        url, data=data,
        headers={"Content-Type": "application/json"},
        method="POST"
    )
    try:
        with urllib.request.urlopen(req, timeout=15) as resp:
            return json.loads(resp.read())
    except Exception as e:
        log.warning("Telegram API error: %s", e)
        return None


def send_message(token, chat_id, text):
    # Split long messages (Telegram limit 4096 chars)
    for chunk in [text[i:i+4000] for i in range(0, len(text), 4000)]:
        tg_request(token, "sendMessage", {"chat_id": chat_id, "text": chunk})


def chat_with_agent(agent_url, message, history):
    """Send message to agent using OpenAI-compatible API, return reply text."""
    messages = history + [{"role": "user", "content": message}]
    payload = json.dumps({
        "model": "default",
        "messages": messages,
        "stream": False,
        "max_tokens": 1024,
    }).encode()

    req = urllib.request.Request(
        f"{agent_url}/v1/chat/completions",
        data=payload,
        headers={"Content-Type": "application/json"},
        method="POST"
    )
    try:
        with urllib.request.urlopen(req, timeout=120) as resp:
            data = json.loads(resp.read())
            return data["choices"][0]["message"]["content"]
    except urllib.error.HTTPError as e:
        body = e.read().decode()
        log.error("Agent HTTP error %s: %s", e.code, body)
        return f"[Agent error {e.code}] {body[:200]}"
    except Exception as e:
        log.error("Agent error: %s", e)
        return f"[Connection error] {e}"


def main():
    env = load_env()
    token = env.get("TELEGRAM_TOKEN", "")
    if not token:
        log.error("TELEGRAM_TOKEN not set in %s — exiting.", ENV_FILE)
        sys.exit(1)

    allowed_raw = env.get("ALLOWED_USERS", "")
    allowed = set(allowed_raw.split(",")) - {""} if allowed_raw else set()

    agent_url = env.get("AGENT_URL", "") or AGENT_URL_DEFAULT

    log.info("ClawbotOS Telegram bot started. Agent URL: %s", agent_url)
    if allowed:
        log.info("Allowed user IDs: %s", allowed)
    else:
        log.info("No ALLOWED_USERS set — accepting messages from everyone.")

    # Per-chat conversation history (last N turns kept in memory)
    MAX_HISTORY = 10
    histories = {}

    offset = 0
    while True:
        # Re-read env on each poll cycle (live config reload)
        env = load_env()
        new_token = env.get("TELEGRAM_TOKEN", token)
        if new_token != token:
            token = new_token
            log.info("Token reloaded.")
        allowed_raw = env.get("ALLOWED_USERS", "")
        allowed = set(allowed_raw.split(",")) - {""} if allowed_raw else set()
        agent_url = env.get("AGENT_URL", "") or AGENT_URL_DEFAULT

        result = tg_request(token, "getUpdates", {
            "offset": offset, "timeout": 30, "allowed_updates": ["message"]
        })

        if not result or not result.get("ok"):
            time.sleep(5)
            continue

        for update in result.get("result", []):
            offset = update["update_id"] + 1
            msg = update.get("message", {})
            chat_id = str(msg.get("chat", {}).get("id", ""))
            user_id = str(msg.get("from", {}).get("id", ""))
            text = msg.get("text", "").strip()

            if not chat_id or not text:
                continue

            if allowed and user_id not in allowed:
                log.info("Ignored message from user %s (not allowed)", user_id)
                send_message(token, chat_id, "Sorry, you are not authorized to use this bot.")
                continue

            if text == "/start":
                histories.pop(chat_id, None)
                send_message(token, chat_id,
                    "ClawbotOS AI Bot\n\nSend me any message to chat with the AI.\nUse /reset to start a new conversation.")
                continue

            if text == "/reset":
                histories.pop(chat_id, None)
                send_message(token, chat_id, "Conversation reset.")
                continue

            if text == "/status":
                try:
                    with urllib.request.urlopen(
                        "http://127.0.0.1:8089/stats", timeout=5
                    ) as resp:
                        stats = json.loads(resp.read())
                    status_text = (
                        f"System Status\n"
                        f"CPU: {stats.get('cpu', '?')}%\n"
                        f"RAM: {stats.get('ram', '?')}%\n"
                        f"Disk: {stats.get('disk', '?')}%\n"
                        f"Temp: {stats.get('temp', '?')}°C"
                    )
                except Exception:
                    status_text = "Could not retrieve system status."
                send_message(token, chat_id, status_text)
                continue

            # Regular chat message
            history = histories.get(chat_id, [])
            log.info("User %s: %s", user_id, text[:80])
            reply = chat_with_agent(agent_url, text, history)
            send_message(token, chat_id, reply)

            # Update history
            history.append({"role": "user", "content": text})
            history.append({"role": "assistant", "content": reply})
            # Keep last MAX_HISTORY exchanges
            histories[chat_id] = history[-(MAX_HISTORY * 2):]


if __name__ == "__main__":
    main()
