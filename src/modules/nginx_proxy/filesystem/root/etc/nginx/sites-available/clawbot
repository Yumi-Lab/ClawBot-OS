# ClawbotOS nginx reverse proxy configuration
# Serves the static dashboard on port 80 and provides API endpoint proxying

server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name clawbot.local _;

    client_max_body_size 50M;

    # ClawbotOS dashboard (static HTML) -- main interface at root
    location / {
        root /home/pi/clawbot-dashboard;
        index index.html;
        try_files $uri $uri/ /index.html;
    }

    # System status API (CPU, RAM, disk, temp, uptime, services)
    location /api/system/ {
        proxy_pass http://127.0.0.1:8089/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_read_timeout 10s;
        add_header Access-Control-Allow-Origin *;
    }

    # ClawbotCore — chat completions API (longest prefix match wins)
    location /api/core/v1/ {
        proxy_pass http://127.0.0.1:8090/v1/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;

        # Support long-running tool loops + SSE streaming
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
        proxy_buffering off;
    }

    # ClawbotCore — module registry, health (shorter prefix)
    location /api/core/ {
        proxy_pass http://127.0.0.1:8090/core/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;

        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
        proxy_buffering off;
    }

    # Health check endpoint
    location /health {
        access_log off;
        return 200 '{"status":"ok","service":"clawbotos"}';
        add_header Content-Type application/json;
    }

    # Static error page
    error_page 502 503 504 /50x.html;
    location = /50x.html {
        root /usr/share/nginx/html;
        internal;
    }
}
