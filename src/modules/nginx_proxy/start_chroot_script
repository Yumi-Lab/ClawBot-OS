# shellcheck enable=require-variable-braces
set -Ee

# shellcheck disable=SC1091
source /common.sh
install_cleanup_trap

echo_green "Installing nginx reverse proxy ..."

## Step 1: Install nginx (purge stale packages from base image, then clean install)
apt-get update --allow-releaseinfo-change
apt-get purge -y nginx nginx-common nginx-core nginx-full nginx-light 2>/dev/null || true
apt-get install -y nginx
## END Step 1

## Step 2: Deploy configuration files and dashboard
echo_green "Deploying nginx configuration ..."
unpack /filesystem/root /

## Step 2b: Try to fetch latest dashboard from GitHub (fallback to bundled)
DASHBOARD_REPO="Yumi-Lab/ClawbotCore-WebUI"
DASHBOARD_DIR="/home/pi/clawbot-dashboard"
mkdir -p "${DASHBOARD_DIR}"
echo_green "Fetching latest dashboard from GitHub ..."
if curl -fsSL --max-time 30 \
    "https://github.com/${DASHBOARD_REPO}/releases/latest/download/index.html" \
    -o "${DASHBOARD_DIR}/index.html.tmp" 2>/dev/null; then
    mv "${DASHBOARD_DIR}/index.html.tmp" "${DASHBOARD_DIR}/index.html"
    curl -fsSL --max-time 10 \
        "https://github.com/${DASHBOARD_REPO}/releases/latest/download/VERSION" \
        -o "${DASHBOARD_DIR}/VERSION" 2>/dev/null || true
    echo_green "Dashboard fetched from GitHub releases."
else
    echo_green "GitHub unreachable — using bundled dashboard (can update later via clawbot-update-dashboard)."
    echo "0.0.0" > "${DASHBOARD_DIR}/VERSION"
fi
chown -R pi:pi "${DASHBOARD_DIR}"
## END Step 2b

## Step 3: Remove default site, ensure sites-enabled exists
mkdir -p /etc/nginx/sites-enabled
rm -f /etc/nginx/sites-enabled/default
## END Step 3

## Step 4: Enable clawbot site
ln -sf /etc/nginx/sites-available/clawbot /etc/nginx/sites-enabled/clawbot
## END Step 4

## Step 5: Optimize log rotation (14d -> 2d)
if [[ -f /etc/logrotate.d/nginx ]]; then
    sed -i 's/rotate 14/rotate 2/' /etc/logrotate.d/nginx
fi
## END Step 5

## Step 6: Enable nginx
echo_green "Enabling nginx.service ..."
if [[ -f /lib/systemd/system/nginx.service ]]; then
    systemctl_if_exists enable nginx.service || \
        ln -sf /lib/systemd/system/nginx.service /etc/systemd/system/multi-user.target.wants/nginx.service
else
    echo_green "WARNING: nginx.service unit not found, skipping enable"
fi
## END Step 6

echo_green "Installing nginx reverse proxy ... DONE!"
