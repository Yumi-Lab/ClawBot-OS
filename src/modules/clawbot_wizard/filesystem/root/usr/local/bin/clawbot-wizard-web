#!/usr/bin/env python3
"""
ClawbotOS First-Boot Web Wizard — HTTP server (port 8099)
Serves the touchscreen setup wizard for SmartPad (cage + Chromium kiosk).

Endpoints:
  GET  /           → wizard HTML
  GET  /api/status → {ip, mac, device_code, activate_url, activated}
  GET  /api/networks → {networks: [{ssid, signal}]}
  POST /api/wifi   → {ssid, password} → {ok, message}
  GET  /api/qr.png → QR code PNG (via qrencode)

Written by Yumi Lab — BUSL-1.1
"""

import json
import os
import socket
import subprocess
import sys
from http.server import BaseHTTPRequestHandler, HTTPServer

PORT = 8099
ACTIVATED_SIGNAL = "/tmp/clawbot-activated"
ACTIVATE_URL_BASE = "https://openjarvis.io/activate?mac="


# ── Device identity (computed once at startup) ────────────────────────────────

def _get_mac() -> str:
    for iface in ["eth0", "end0"]:
        try:
            with open(f"/sys/class/net/{iface}/address") as f:
                mac = f.read().strip()
            if mac and mac != "00:00:00:00:00:00":
                return mac.upper()
        except Exception:
            pass
    return "unknown"


def _get_ip() -> str:
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.connect(("8.8.8.8", 80))
        ip = s.getsockname()[0]
        s.close()
        return ip
    except Exception:
        return ""


MAC = _get_mac()
MAC_CLEAN = MAC.replace(":", "") if MAC != "unknown" else ""
DEVICE_CODE = (
    f"{MAC_CLEAN[:4]}-{MAC_CLEAN[4:8]}-{MAC_CLEAN[8:]}"
    if len(MAC_CLEAN) == 12 else MAC
)
ACTIVATE_URL = (
    f"{ACTIVATE_URL_BASE}{MAC_CLEAN}" if MAC_CLEAN else "https://openjarvis.io"
)


# ── WiFi helpers ──────────────────────────────────────────────────────────────

def scan_networks() -> list:
    try:
        subprocess.run(
            ["nmcli", "device", "wifi", "rescan"],
            capture_output=True, timeout=8
        )
        r = subprocess.run(
            ["nmcli", "-t", "-f", "SSID,SIGNAL", "device", "wifi", "list"],
            capture_output=True, text=True, timeout=8
        )
        nets, seen = [], set()
        for line in r.stdout.splitlines():
            parts = line.split(":")
            if len(parts) >= 2:
                ssid = parts[0].strip()
                sig = parts[1].strip()
                if ssid and ssid != "--" and ssid not in seen:
                    seen.add(ssid)
                    nets.append({
                        "ssid": ssid,
                        "signal": int(sig) if sig.isdigit() else 0
                    })
        nets.sort(key=lambda x: -x["signal"])
        return nets[:14]
    except Exception:
        return []


def connect_wifi(ssid: str, password: str) -> tuple:
    try:
        cmd = ["nmcli", "device", "wifi", "connect", ssid]
        if password:
            cmd += ["password", password]
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
        ok = r.returncode == 0
        msg = (r.stdout.strip() or r.stderr.strip())[:200]
        return ok, msg
    except Exception as e:
        return False, str(e)


def make_qr_png(url: str) -> bytes | None:
    try:
        r = subprocess.run(
            ["qrencode", "-t", "PNG", "-s", "10", "-m", "3", "-o", "-", url],
            capture_output=True, timeout=5
        )
        return r.stdout if r.returncode == 0 else None
    except Exception:
        return None


