<script>
// ── State ──────────────────────────────────────────────────────────────────────
let selectedSsid = '';
let shiftOn = false;
let pollTimer = null;
let activateUrl = 'https://openjarvis.io';
let deviceIp = '';

// ── Virtual keyboard ──────────────────────────────────────────────────────────
const KB_ROWS = [
  ['1','2','3','4','5','6','7','8','9','0','-'],
  ['q','w','e','r','t','y','u','i','o','p'],
  ['a','s','d','f','g','h','j','k','l'],
  ['⇧','z','x','c','v','b','n','m','⌫'],
];

function buildKeyboard() {
  KB_ROWS.forEach((row, ri) => {
    const rowEl = document.getElementById('kb-r' + ri);
    row.forEach(k => {
      const btn = document.createElement('button');
      btn.className = 'kb-key';
      if (k === '⇧') btn.className += ' kb-wide';
      else if (k === '⌫') btn.className += ' kb-wide';
      btn.textContent = k;
      btn.dataset.k = k;
      const handler = e => { e.preventDefault(); pressKey(btn); };
      btn.addEventListener('touchstart', handler, {passive: false});
      btn.addEventListener('mousedown', handler);
      rowEl.appendChild(btn);
    });
    if (ri === 3) {
      // Space
      const sp = document.createElement('button');
      sp.className = 'kb-key kb-space';
      sp.textContent = 'space';
      sp.dataset.k = ' ';
      const hs = e => { e.preventDefault(); pressKey(sp); };
      sp.addEventListener('touchstart', hs, {passive: false});
      sp.addEventListener('mousedown', hs);
      rowEl.appendChild(sp);
      // Enter
      const en = document.createElement('button');
      en.className = 'kb-key kb-enter kb-wide';
      en.textContent = 'Enter';
      en.dataset.k = 'enter';
      const he = e => { e.preventDefault(); pressKey(en); };
      en.addEventListener('touchstart', he, {passive: false});
      en.addEventListener('mousedown', he);
      rowEl.appendChild(en);
    }
  });
}

function pressKey(btn) {
  btn.classList.add('pressed');
  setTimeout(() => btn.classList.remove('pressed'), 130);
  const k = btn.dataset.k;
  const inp = document.getElementById('pw-inp');
  if (!inp) return;
  if (k === '⇧') {
    shiftOn = !shiftOn;
    updateShift();
  } else if (k === '⌫') {
    inp.value = inp.value.slice(0, -1);
  } else if (k === 'enter') {
    connectWifi();
  } else {
    inp.value += shiftOn ? k.toUpperCase() : k;
    if (shiftOn) { shiftOn = false; updateShift(); }
  }
}

function updateShift() {
  document.querySelectorAll('.kb-key').forEach(b => {
    const k = b.dataset.k;
    if (k && k.length === 1 && k >= 'a' && k <= 'z') {
      b.textContent = shiftOn ? k.toUpperCase() : k;
    }
  });
}

function openKeyboard() {
  document.getElementById('kb').classList.add('open');
  document.getElementById('content').classList.add('kb-open');
  setTimeout(() => {
    document.getElementById('pw-inp').scrollIntoView({behavior: 'smooth', block: 'nearest'});
  }, 60);
}

function closeKeyboard() {
  document.getElementById('kb').classList.remove('open');
  document.getElementById('content').classList.remove('kb-open');
}

document.addEventListener('touchstart', e => {
  const kb = document.getElementById('kb');
  const inp = document.getElementById('pw-inp');
  if (kb.classList.contains('open') && !kb.contains(e.target) && e.target !== inp) {
    closeKeyboard();
  }
}, {passive: true});

// ── Screens ───────────────────────────────────────────────────────────────────
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  const labels = {
    'wifi-screen': 'Step 1 · WiFi',
    'qr-screen': 'Step 2 · Activate',
    'done-screen': 'Done!'
  };
  document.getElementById('hdr-step').textContent = labels[id] || '';
}

// ── WiFi ──────────────────────────────────────────────────────────────────────
function sigBars(signal) {
  const bars = signal > 75 ? 4 : signal > 50 ? 3 : signal > 25 ? 2 : 1;
  let h = '';
  for (let i = 1; i <= 4; i++) h += `<div class="net-sig-bar${i <= bars ? ' on' : ''}"></div>`;
  return h;
}

function escHtml(s) {
  return String(s).replace(/[&<>"]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));
}

async function scanNetworks() {
  const list = document.getElementById('net-list');
  list.innerHTML = '<div style="color:var(--td);font-size:.85rem;text-align:center;padding:20px;display:flex;align-items:center;justify-content:center;gap:8px"><div class="spin"></div> Scanning…</div>';
  try {
    const r = await fetch('/api/networks', {signal: AbortSignal.timeout(18000)});
    const d = await r.json();
    renderNetworks(d.networks || []);
  } catch {
    list.innerHTML = '<div style="color:var(--er);font-size:.85rem;text-align:center;padding:20px">Scan failed</div>';
  }
}

function renderNetworks(nets) {
  const list = document.getElementById('net-list');
  list.innerHTML = '';
  if (!nets.length) {
    list.innerHTML = '<div style="color:var(--td);font-size:.85rem;text-align:center;padding:20px">No networks found — try rescanning.</div>';
  }
  nets.forEach(n => {
    const el = document.createElement('div');
    el.className = 'net-item';
    el.innerHTML = `<div class="net-sig">${sigBars(n.signal)}</div><div class="net-ssid">${escHtml(n.ssid)}</div>`;
    const tap = () => selectNetwork(n.ssid);
    el.addEventListener('click', tap);
    el.addEventListener('touchend', e => { e.preventDefault(); tap(); });
    list.appendChild(el);
  });
  // Manual entry
  const manual = document.createElement('div');
  manual.className = 'net-item';
  manual.innerHTML = `<div class="net-sig"><div class="net-sig-bar"></div><div class="net-sig-bar"></div><div class="net-sig-bar"></div><div class="net-sig-bar"></div></div><div class="net-ssid" style="color:var(--ts)">✏ Enter SSID manually…</div>`;
  manual.addEventListener('click', () => selectNetwork('__manual__'));
  manual.addEventListener('touchend', e => { e.preventDefault(); selectNetwork('__manual__'); });
  list.appendChild(manual);
}

function selectNetwork(ssid) {
  selectedSsid = ssid === '__manual__' ? '' : ssid;
  document.getElementById('pw-ssid').textContent = ssid === '__manual__' ? '(type manually)' : ssid;
  document.getElementById('pw-inp').value = '';
  document.getElementById('pw-panel').classList.add('open');
  setMsg('wifi-msg', '', '');
  document.getElementById('btn-connect').disabled = false;
  document.getElementById('btn-connect').innerHTML = 'Connect →';
  // Scroll down to show the panel
  setTimeout(() => {
    document.getElementById('pw-panel').scrollIntoView({behavior: 'smooth', block: 'nearest'});
  }, 50);
}

function closePwPanel() {
  document.getElementById('pw-panel').classList.remove('open');
  closeKeyboard();
}

function togglePw() {
  const inp = document.getElementById('pw-inp');
  const tog = document.getElementById('pw-tog');
  if (inp.type === 'password') { inp.type = 'text'; tog.textContent = 'Hide'; }
  else { inp.type = 'password'; tog.textContent = 'Show'; }
}

async function connectWifi() {
  let ssid = selectedSsid;
  if (!ssid) {
    // manual entry: SSID is in a separate input (not implemented — use pw-inp for now)
    // Actually we should show a separate SSID input for manual entry
    // For simplicity, if selectedSsid is empty we ask via prompt (works in Chromium)
    ssid = (window.prompt && window.prompt('Enter WiFi SSID:')) || '';
    if (!ssid) return;
  }
  const pw = document.getElementById('pw-inp').value;
  const btn = document.getElementById('btn-connect');
  btn.disabled = true;
  btn.innerHTML = '<div class="spin"></div>';
  setMsg('wifi-msg', '', '');
  closeKeyboard();
  try {
    const r = await fetch('/api/wifi', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ssid, password: pw}),
      signal: AbortSignal.timeout(35000)
    });
    const d = await r.json();
    if (d.ok) {
      setMsg('wifi-msg', '✓ Connected!', 'ok');
      setTimeout(goToQr, 1000);
    } else {
      setMsg('wifi-msg', d.message || 'Connection failed — check password', 'err');
      btn.disabled = false;
      btn.textContent = 'Retry →';
    }
  } catch {
    setMsg('wifi-msg', 'Timeout — check password and try again', 'err');
    btn.disabled = false;
    btn.textContent = 'Retry →';
  }
}

function skipWifi() { goToQr(); }

// ── QR / Activation ───────────────────────────────────────────────────────────
function goToQr() {
  closeKeyboard();
  showScreen('qr-screen');
  loadStatus();
  pollTimer = setInterval(pollActivation, 3000);
}

async function loadStatus() {
  try {
    const r = await fetch('/api/status', {signal: AbortSignal.timeout(4000)});
    const d = await r.json();
    activateUrl = d.activate_url || 'https://openjarvis.io';
    deviceIp = d.ip || '';
    document.getElementById('dev-code').textContent = d.device_code || '----';
    document.getElementById('qr-mac').textContent = d.mac || '--';
    if (d.activated) onActivated(d);
  } catch {}
}

async function pollActivation() {
  try {
    const r = await fetch('/api/status', {signal: AbortSignal.timeout(4000)});
    const d = await r.json();
    deviceIp = d.ip || deviceIp;
    if (d.activated) { clearInterval(pollTimer); onActivated(d); }
  } catch {}
}

function onActivated(d) {
  clearInterval(pollTimer);
  document.getElementById('act-pulse').classList.add('ok');
  document.getElementById('act-status').textContent = 'Activated!';
  setTimeout(() => {
    showScreen('done-screen');
    document.getElementById('done-ip').textContent =
      (d.ip ? `IP: ${d.ip} — ` : '') + 'Opening dashboard…';
    setTimeout(() => { window.location.href = 'http://localhost'; }, 2500);
  }, 800);
}

function copyCode() {
  const code = document.getElementById('dev-code').textContent;
  if (navigator.clipboard && code && code !== '----') {
    navigator.clipboard.writeText(code).then(() => {
      const btn = document.getElementById('btn-copy');
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
    });
  }
}

function openJarvis() {
  window.open(activateUrl, '_blank');
}

// ── Helpers ───────────────────────────────────────────────────────────────────
function setMsg(id, text, type) {
  const el = document.getElementById(id);
  if (!el) return;
  el.textContent = text;
  el.className = 'msg' + (type ? ' ' + type : '');
}

// ── Init ──────────────────────────────────────────────────────────────────────
buildKeyboard();
scanNetworks();
// Pre-load QR image (will be refreshed later by qr-screen init)
</script>
</body>
</html>
"""

# ── HTTP server ───────────────────────────────────────────────────────────────

class Handler(BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        pass  # silence access logs

    def send_json(self, code, data):
        body = json.dumps(data).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Access-Control-Allow-Origin", "*")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_OPTIONS(self):
        self.send_response(200)
        self.send_header("Access-Control-Allow-Origin", "*")
        self.send_header("Access-Control-Allow-Methods", "GET, POST, OPTIONS")
        self.send_header("Access-Control-Allow-Headers", "Content-Type")
        self.end_headers()

    def do_GET(self):
        path = self.path.split("?")[0]

        if path in ("/", ""):
            body = WIZARD_HTML.encode()
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)

        elif path == "/api/status":
            self.send_json(200, {
                "ip": _get_ip(),
                "mac": MAC,
                "device_code": DEVICE_CODE,
                "activate_url": ACTIVATE_URL,
                "activated": os.path.exists(ACTIVATED_SIGNAL),
            })

        elif path == "/api/networks":
            nets = scan_networks()
            self.send_json(200, {"networks": nets})

        elif path == "/api/qr.png":
            png = make_qr_png(ACTIVATE_URL)
            if png:
                self.send_response(200)
                self.send_header("Content-Type", "image/png")
                self.send_header("Cache-Control", "no-cache")
                self.send_header("Content-Length", str(len(png)))
                self.end_headers()
                self.wfile.write(png)
            else:
                self.send_response(503)
                self.end_headers()

        else:
            self.send_response(404)
            self.end_headers()

    def do_POST(self):
        length = int(self.headers.get("Content-Length", 0))
        try:
            data = json.loads(self.rfile.read(length) or b"{}")
        except Exception:
            self.send_json(400, {"error": "invalid JSON"})
            return

        path = self.path.split("?")[0]

        if path == "/api/wifi":
            ssid = data.get("ssid", "").strip()
            password = data.get("password", "")
            if not ssid:
                self.send_json(400, {"ok": False, "message": "Missing SSID"})
                return
            ok, msg = connect_wifi(ssid, password)
            self.send_json(200 if ok else 400, {"ok": ok, "message": msg})

        else:
            self.send_response(404)
            self.end_headers()


if __name__ == "__main__":
    server = HTTPServer(("127.0.0.1", PORT), Handler)
    print(f"ClawbotOS wizard server on http://127.0.0.1:{PORT}", flush=True)
    server.serve_forever()
