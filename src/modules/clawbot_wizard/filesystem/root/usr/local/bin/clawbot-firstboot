#!/usr/bin/env bash
#### ClawbotOS First-Boot Setup Wizard
####
#### Unified wizard: detects screen presence.
####   - With screen: interactive WiFi setup + QR code display
####   - Headless: console message with MAC, waits for cloud activation
####
#### Cloud provisioning is handled by clawbot-cloud.service (WebSocket).
#### This wizard only provides the local UX (dialog or console output).
####
#### Written by Yumi Lab — BUSL-1.1

set -e

DIALOG="$(command -v dialog 2>/dev/null || true)"
BT="ClawbotOS Setup Wizard"
WT=20
WW=70
ACTIVATED_SIGNAL="/tmp/clawbot-activated"

# ── Detect environment ────────────────────────────────────────────────────────

get_mac() {
    cat /sys/class/net/eth0/address 2>/dev/null || \
    cat /sys/class/net/wlan0/address 2>/dev/null || \
    echo "unknown"
}

get_ip() {
    hostname -I 2>/dev/null | awk '{print $1}'
}

MAC="$(get_mac | tr '[:lower:]' '[:upper:]')"
MAC_CLEAN="$(echo "${MAC}" | tr -d ':')"
ACTIVATE_URL="https://clawbot-api.yumi-lab.com/activate?mac=${MAC_CLEAN}"
HAS_SCREEN=false
[[ -e /dev/fb0 ]] && HAS_SCREEN=true

# ── Screen mode: interactive dialog ──────────────────────────────────────────

welcome_msg() {
    "${DIALOG}" --backtitle "${BT}" --title "Welcome to ClawbotOS" \
        --no-cancel --msgbox "\
Welcome to ClawbotOS for your Yumi Lab board!

This wizard will help you set up your device.

The setup will:
  1. Configure WiFi (optional)
  2. Display a QR code to link your device
  3. Wait for cloud activation

Press OK to continue..." ${WT} ${WW}
}

configure_wifi() {
    if ! command -v nmcli &>/dev/null; then
        return
    fi

    "${DIALOG}" --backtitle "${BT}" --title "WiFi Configuration" \
        --yesno "Do you want to connect to a WiFi network?\n\n(Select No to use Ethernet only)" \
        10 ${WW} || return

    local ssid
    ssid=$("${DIALOG}" --backtitle "${BT}" --title "WiFi - Network Name" \
        --inputbox "Enter WiFi network name (SSID):" \
        10 ${WW} 3>&1 1>&2 2>&3) || return

    if [[ -z "${ssid}" ]]; then
        return
    fi

    local password
    password=$("${DIALOG}" --backtitle "${BT}" --title "WiFi - Password" \
        --insecure --passwordbox "Enter WiFi password for '${ssid}':\n(Leave empty for open network)" \
        10 ${WW} 3>&1 1>&2 2>&3) || return

    "${DIALOG}" --backtitle "${BT}" --title "WiFi - Connecting..." \
        --infobox "Connecting to '${ssid}'..." 5 ${WW}

    if [[ -n "${password}" ]]; then
        nmcli device wifi connect "${ssid}" password "${password}" 2>/dev/null || true
    else
        nmcli device wifi connect "${ssid}" 2>/dev/null || true
    fi

    sleep 3

    if nmcli -t -f STATE general 2>/dev/null | grep -q "connected"; then
        "${DIALOG}" --backtitle "${BT}" --title "WiFi" \
            --msgbox "Connected to '${ssid}' successfully!" 8 ${WW}
    else
        "${DIALOG}" --backtitle "${BT}" --title "WiFi" \
            --msgbox "Could not connect to '${ssid}'.\nCheck the password and try again via:\n  nmcli device wifi connect \"${ssid}\"" \
            10 ${WW}
    fi
}

show_qr_on_screen() {
    clear
    echo ""
    echo "  ┌─────────────────────────────────────────────────────────────┐"
    echo "  │          Clawbot Cloud — Link your device                   │"
    echo "  │                                                             │"
    echo "  │  Scan the QR code below with the Yumi-Lab app              │"
    echo "  │  or visit the URL to activate your device.                  │"
    echo "  └─────────────────────────────────────────────────────────────┘"
    echo ""
    if command -v qrencode &>/dev/null; then
        qrencode -t utf8 -m 2 "${ACTIVATE_URL}" 2>/dev/null || true
    fi
    echo ""
    echo "  MAC : ${MAC}"
    echo "  URL : ${ACTIVATE_URL}"
    echo ""
}

wait_for_activation() {
    local ip
    # Show waiting dialog that auto-refreshes
    while [[ ! -f "${ACTIVATED_SIGNAL}" ]]; do
        ip="$(get_ip)"
        "${DIALOG}" --backtitle "${BT}" --title "Waiting for activation..." \
            --infobox "\
Scan the QR code displayed above to activate your device.

MAC : ${MAC}
IP  : ${ip:-no network}
Web : http://${ip:-clawbot.local}

Cloud status: waiting...

The wizard will continue automatically once activated." \
            14 ${WW}
        sleep 5
    done

    "${DIALOG}" --backtitle "${BT}" --title "Activated!" \
        --msgbox "\
Your device has been activated!

Access your AI dashboard at:
    http://clawbot.local

SSH access:
    User: pi
    Password: yumi

Press OK to continue." ${WT} ${WW}
}

# ── Headless mode: console output ────────────────────────────────────────────

headless_wait() {
    local ip fw
    fw="$(grep 'VERSION=' /etc/clawbot-release 2>/dev/null | cut -d= -f2 | tr -d '"' || echo '?')"
    ip="$(get_ip)"

    clear
    echo ""
    echo "  ┌────────────────────────────────────────────────┐"
    echo "  │  ClawbotOS v${fw}                               │"
    echo "  │                                                │"
    echo "  │  MAC : ${MAC}                     │"
    echo "  │  IP  : ${ip:-no network yet}                          │"
    echo "  │                                                │"
    echo "  │  Cloud : waiting for activation...             │"
    echo "  │  Scan the QR code on the device case           │"
    echo "  │  or visit:                                     │"
    echo "  │  ${ACTIVATE_URL}  │"
    echo "  └────────────────────────────────────────────────┘"
    echo ""

    while [[ ! -f "${ACTIVATED_SIGNAL}" ]]; do
        sleep 5
    done

    echo ""
    echo "  Device activated! Services are being configured..."
    echo ""
}

# ── Main ─────────────────────────────────────────────────────────────────────

if ${HAS_SCREEN} && [[ -n "${DIALOG}" ]]; then
    # ── SCREEN MODE ──
    chvt 2 2>/dev/null || true
    welcome_msg
    configure_wifi
    show_qr_on_screen
    wait_for_activation
else
    # ── HEADLESS MODE ──
    headless_wait
fi

# Cleanup: disable firstboot (one-shot)
systemctl --quiet disable clawbot-firstboot.service 2>/dev/null || true
rm -f /.firstboot_clawbot

exit 0
