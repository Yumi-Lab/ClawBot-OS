#!/usr/bin/env bash
#### ClawbotOS First-Boot Setup Wizard
####
#### Unified wizard: detects screen presence.
####   - With screen: interactive WiFi setup + QR code display
####   - Headless: console message with MAC, waits for cloud activation
####
#### Cloud provisioning is handled by clawbot-cloud.service (WebSocket).
#### This wizard only provides the local UX (dialog or console output).
####
#### Written by Yumi Lab — BUSL-1.1

set -e

DIALOG="$(command -v dialog 2>/dev/null || true)"
BT="ClawbotOS Setup Wizard"
WT=20
WW=70
ACTIVATED_SIGNAL="/tmp/clawbot-activated"

# ── Detect environment ────────────────────────────────────────────────────────

get_mac() {
    # Ethernet only — WiFi excluded (dongle MAC can change if swapped)
    # eth0 = legacy naming, end0 = predictable naming (Armbian Trixie)
    for iface in eth0 end0; do
        mac=$(cat "/sys/class/net/${iface}/address" 2>/dev/null || true)
        if [[ -n "${mac}" && "${mac}" != "00:00:00:00:00:00" ]]; then
            echo "${mac}"; return
        fi
    done
    echo "unknown"
}

get_ip() {
    hostname -I 2>/dev/null | awk '{print $1}'
}

MAC="$(get_mac | tr '[:lower:]' '[:upper:]')"
MAC_CLEAN="$(echo "${MAC}" | tr -d ':')"
ACTIVATE_URL="https://clawbot-api.yumi-lab.com/activate?mac=${MAC_CLEAN}"
HAS_SCREEN=false
[[ -e /dev/fb0 ]] && HAS_SCREEN=true

# Always start fresh: remove stale activation signal so the wizard waits
# for a real cloud push even if device was previously activated
rm -f "${ACTIVATED_SIGNAL}"

# ── Screen mode: interactive dialog ──────────────────────────────────────────

welcome_msg() {
    "${DIALOG}" --backtitle "${BT}" --title "Welcome to ClawbotOS" \
        --no-cancel --msgbox "\
Welcome to ClawbotOS for your Yumi Lab board!

This wizard will help you set up your device.

The setup will:
  1. Configure WiFi (optional)
  2. Display a QR code to link your device
  3. Wait for cloud activation

Press OK to continue..." ${WT} ${WW}
}

configure_wifi() {
    if ! command -v nmcli &>/dev/null; then
        return
    fi

    "${DIALOG}" --backtitle "${BT}" --title "WiFi Configuration" \
        --yesno "Do you want to connect to a WiFi network?\n\n(Select No to use Ethernet only)" \
        10 ${WW} || return

    # Scan for available networks and show a selectable list
    "${DIALOG}" --backtitle "${BT}" --title "WiFi - Scanning..." \
        --infobox "Scanning for WiFi networks, please wait..." 5 ${WW}
    nmcli device wifi rescan 2>/dev/null || true
    sleep 3

    # Build menu from scan results: SSID + signal strength
    local menu_items=()
    while IFS=: read -r ssid signal; do
        [[ -z "${ssid}" || "${ssid}" == "--" ]] && continue
        menu_items+=("${ssid}" "${signal}%  signal")
    done < <(nmcli -t -f SSID,SIGNAL device wifi list 2>/dev/null \
             | sort -t: -k2 -rn \
             | awk -F: '!seen[$1]++ && NF>=2 && $1!=""' \
             | head -15)

    local ssid
    if [[ ${#menu_items[@]} -gt 0 ]]; then
        ssid=$("${DIALOG}" --backtitle "${BT}" --title "WiFi - Select Network" \
            --menu "Select a WiFi network to connect:" \
            18 ${WW} 10 "${menu_items[@]}" \
            "-- manual --" "Type SSID manually" \
            3>&1 1>&2 2>&3) || return
    else
        ssid="-- manual --"
    fi

    if [[ "${ssid}" == "-- manual --" ]]; then
        ssid=$("${DIALOG}" --backtitle "${BT}" --title "WiFi - Network Name" \
            --inputbox "Enter WiFi network name (SSID):" \
            10 ${WW} 3>&1 1>&2 2>&3) || return
    fi

    [[ -z "${ssid}" ]] && return

    local password
    password=$("${DIALOG}" --backtitle "${BT}" --title "WiFi - Password for '${ssid}'" \
        --insecure --passwordbox "Enter WiFi password:\n(Leave empty for open network)" \
        10 ${WW} 3>&1 1>&2 2>&3) || return

    "${DIALOG}" --backtitle "${BT}" --title "WiFi - Connecting..." \
        --infobox "Connecting to '${ssid}'..." 5 ${WW}

    if [[ -n "${password}" ]]; then
        nmcli device wifi connect "${ssid}" password "${password}" 2>/dev/null || true
    else
        nmcli device wifi connect "${ssid}" 2>/dev/null || true
    fi

    sleep 3

    if nmcli -t -f STATE general 2>/dev/null | grep -q "connected"; then
        "${DIALOG}" --backtitle "${BT}" --title "WiFi ✓" \
            --msgbox "Connected to '${ssid}' successfully!\n\nIP: $(get_ip)" 8 ${WW}
    else
        "${DIALOG}" --backtitle "${BT}" --title "WiFi - Failed" \
            --msgbox "Could not connect to '${ssid}'.\nCheck the password and try again.\n\nRetry later via:\n  nmcli device wifi connect \"${ssid}\"" \
            10 ${WW}
    fi
}

show_qr_and_wait() {
    # Build short device code from MAC (no colons, uppercase, grouped by 4)
    local mac_raw device_code
    mac_raw="$(echo "${MAC}" | tr -d ':' | tr '[:lower:]' '[:upper:]')"
    device_code="${mac_raw:0:4}-${mac_raw:4:4}-${mac_raw:8:4}"

    # Display QR code + status loop on the terminal (no dialog overlay)
    while [[ ! -f "${ACTIVATED_SIGNAL}" ]]; do
        local ip
        ip="$(get_ip)"
        clear
        echo ""
        echo "  ┌─────────────────────────────────────────────────────────────┐"
        echo "  │          Clawbot Cloud — Link your device                   │"
        echo "  │  Scan the QR code or enter the device code to activate      │"
        echo "  └─────────────────────────────────────────────────────────────┘"
        echo ""
        if command -v qrencode &>/dev/null; then
            qrencode -t utf8 -m 2 "${ACTIVATE_URL}" 2>/dev/null || true
        fi
        echo "  ┌─────────────────────────────────────────────────────────────┐"
        echo "  │  No app? Activate manually:                                 │"
        echo "  │                                                             │"
        printf  "  │      Device code:  %-40s│\n" "${device_code}"
        echo "  │                                                             │"
        printf  "  │  URL: %-53s│\n" "${ACTIVATE_URL}"
        echo "  │                                                             │"
        printf  "  │  MAC: %-20s  IP: %-20s│\n" "${MAC}" "${ip:-no network}"
        echo "  │  Status: waiting for activation...                          │"
        echo "  └─────────────────────────────────────────────────────────────┘"
        echo ""
        sleep 5
    done

    clear
    echo ""
    echo "  ✅ Device activated!"
    echo "  Access your dashboard at: http://$(get_ip)"
    echo ""
    sleep 3
}

# ── Headless mode: console output ────────────────────────────────────────────

headless_wait() {
    local ip fw
    fw="$(grep 'VERSION=' /etc/clawbot-release 2>/dev/null | cut -d= -f2 | tr -d '"' || echo '?')"
    ip="$(get_ip)"

    clear
    echo ""
    echo "  ┌────────────────────────────────────────────────┐"
    echo "  │  ClawbotOS v${fw}                               │"
    echo "  │                                                │"
    echo "  │  MAC : ${MAC}                     │"
    echo "  │  IP  : ${ip:-no network yet}                          │"
    echo "  │                                                │"
    echo "  │  Cloud : waiting for activation...             │"
    echo "  │  Scan the QR code on the device case           │"
    echo "  │  or visit:                                     │"
    echo "  │  ${ACTIVATE_URL}  │"
    echo "  └────────────────────────────────────────────────┘"
    echo ""

    while [[ ! -f "${ACTIVATED_SIGNAL}" ]]; do
        sleep 5
    done

    echo ""
    echo "  Device activated! Services are being configured..."
    echo ""
}

# ── Main ─────────────────────────────────────────────────────────────────────

if ${HAS_SCREEN} && [[ -n "${DIALOG}" ]]; then
    # ── SCREEN MODE ──
    chvt 2 2>/dev/null || true
    welcome_msg
    configure_wifi
    show_qr_and_wait
else
    # ── HEADLESS MODE ──
    headless_wait
fi

# Cleanup: disable firstboot (one-shot)
systemctl --quiet disable clawbot-firstboot.service 2>/dev/null || true
rm -f /.firstboot_clawbot

exit 0
