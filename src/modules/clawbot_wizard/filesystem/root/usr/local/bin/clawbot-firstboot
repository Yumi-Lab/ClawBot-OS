#!/usr/bin/env bash
#### ClawbotOS First-Boot Setup Wizard
####
#### Written by Yumi Lab
#### This File is distributed under GPLv3
####

set -e

DIALOG="$(command -v dialog)"
BT="ClawbotOS Setup Wizard"
WT=20
WW=70

# Switch to TTY2
chvt 2 2>/dev/null || true

welcome_msg() {
    "${DIALOG}" --backtitle "${BT}" --title "Welcome to ClawbotOS" \
        --no-cancel --msgbox "\
Welcome to ClawbotOS for your Yumi Lab board!

This wizard will help you configure your AI assistant.

The setup will:
  1. Configure WiFi (optional)
  2. Configure your AI provider API key
  3. Start all services

Press OK to continue..." ${WT} ${WW}
}

configure_wifi() {
    # Check if nmcli is available
    if ! command -v nmcli &>/dev/null; then
        return
    fi

    # Ask user if they want to configure WiFi
    "${DIALOG}" --backtitle "${BT}" --title "WiFi Configuration" \
        --yesno "Do you want to connect to a WiFi network?\n\n(Select No to use Ethernet only)" \
        10 ${WW} || return

    # Get SSID
    local ssid
    ssid=$("${DIALOG}" --backtitle "${BT}" --title "WiFi - Network Name" \
        --inputbox "Enter WiFi network name (SSID):" \
        10 ${WW} 3>&1 1>&2 2>&3) || return

    if [[ -z "${ssid}" ]]; then
        return
    fi

    # Get password
    local password
    password=$("${DIALOG}" --backtitle "${BT}" --title "WiFi - Password" \
        --insecure --passwordbox "Enter WiFi password for '${ssid}':\n(Leave empty for open network)" \
        10 ${WW} 3>&1 1>&2 2>&3) || return

    # Connect using nmcli
    "${DIALOG}" --backtitle "${BT}" --title "WiFi - Connecting..." \
        --infobox "Connecting to '${ssid}'..." 5 ${WW}

    if [[ -n "${password}" ]]; then
        nmcli device wifi connect "${ssid}" password "${password}" 2>/dev/null || true
    else
        nmcli device wifi connect "${ssid}" 2>/dev/null || true
    fi

    sleep 3

    # Check if connected
    if nmcli -t -f STATE general 2>/dev/null | grep -q "connected"; then
        "${DIALOG}" --backtitle "${BT}" --title "WiFi" \
            --msgbox "Connected to '${ssid}' successfully!" 8 ${WW}
    else
        "${DIALOG}" --backtitle "${BT}" --title "WiFi" \
            --msgbox "Could not connect to '${ssid}'.\nCheck the password and try again via:\n  nmcli device wifi connect \"${ssid}\"" \
            10 ${WW}
    fi
}

configure_api_key() {
    local provider api_key model base_url

    # Ask for LLM provider
    provider=$("${DIALOG}" --backtitle "${BT}" --title "LLM Provider" \
        --menu "Select your LLM provider:" ${WT} ${WW} 8 \
        "clawbot"    "Clawbot Cloud (subscription — no API key needed)" \
        "anthropic"  "Anthropic (Claude)" \
        "openai"     "OpenAI (GPT-4o, etc.)" \
        "openrouter" "OpenRouter (multi-provider)" \
        "deepseek"   "DeepSeek" \
        "ollama"     "Ollama (running on another machine)" \
        "custom"     "Custom OpenAI-compatible endpoint" \
        "skip"       "Skip for now (configure later)" \
        3>&1 1>&2 2>&3) || provider="skip"

    if [[ "${provider}" == "skip" ]]; then
        return
    fi

    # Ask for key (label depends on provider)
    if [[ "${provider}" == "clawbot" ]]; then
        api_key=$("${DIALOG}" --backtitle "${BT}" --title "Clawbot Cloud — Subscription Key" \
            --insecure --passwordbox "Enter your Clawbot Cloud subscription key:\n(Get yours at clawbot.io)" \
            10 ${WW} 3>&1 1>&2 2>&3) || api_key=""
    else
        api_key=$("${DIALOG}" --backtitle "${BT}" --title "API Key" \
            --insecure --passwordbox "Enter your ${provider} API key:" \
            10 ${WW} 3>&1 1>&2 2>&3) || api_key=""
    fi

    if [[ -z "${api_key}" ]]; then
        return
    fi

    # Set defaults based on provider
    case "${provider}" in
        clawbot)
            model="clawbot-smart"
            base_url="https://api.clawbot.io/v1"
            ;;
        openai)
            model="gpt-4o"
            base_url="https://api.openai.com/v1"
            ;;
        anthropic)
            model="claude-sonnet-4-20250514"
            base_url="https://api.anthropic.com/v1"
            ;;
        openrouter)
            model="anthropic/claude-sonnet-4-20250514"
            base_url="https://openrouter.ai/api/v1"
            ;;
        deepseek)
            model="deepseek-chat"
            base_url="https://api.deepseek.com/v1"
            ;;
        ollama)
            base_url=$("${DIALOG}" --backtitle "${BT}" --title "Ollama URL" \
                --inputbox "Enter Ollama server URL:" 10 ${WW} \
                "http://192.168.1.100:11434" 3>&1 1>&2 2>&3) || base_url=""
            model="llama3"
            ;;
        custom)
            base_url=$("${DIALOG}" --backtitle "${BT}" --title "Custom API URL" \
                --inputbox "Enter API base URL:" 10 ${WW} 3>&1 1>&2 2>&3) || base_url=""
            model=$("${DIALOG}" --backtitle "${BT}" --title "Model Name" \
                --inputbox "Enter model name:" 10 ${WW} 3>&1 1>&2 2>&3) || model=""
            ;;
    esac

    # Write PicoClaw config
    cat > /home/pi/.picoclaw/config.json << PICOEOF
{
  "gateway": {
    "host": "0.0.0.0",
    "port": 8080
  },
  "agents": {
    "defaults": {
      "workspace": "~/.picoclaw/workspace",
      "max_tokens": 4096,
      "temperature": 0.7
    }
  },
  "model_list": [
    {
      "model_name": "default",
      "model": "${model}",
      "api_key": "${api_key}",
      "base_url": "${base_url}",
      "request_timeout": 120
    }
  ],
  "tools": {
    "web": {
      "duckduckgo": {
        "enabled": true,
        "max_results": 5
      }
    }
  },
  "log_level": "info"
}
PICOEOF
    chown pi:pi /home/pi/.picoclaw/config.json
    chmod 600 /home/pi/.picoclaw/config.json

}

finish_setup() {
    "${DIALOG}" --backtitle "${BT}" --title "Setup Complete!" \
        --no-cancel --msgbox "\
ClawbotOS setup is complete!

Access your AI dashboard at:
    http://clawbot.local

SSH access:
    User: pi
    Password: yumi

The device will now reboot to apply changes.

Thank you for choosing ClawbotOS!" ${WT} ${WW}
}

# --- MAIN ---

welcome_msg
configure_wifi
configure_api_key
finish_setup

# Cleanup: disable firstboot
systemctl --quiet disable clawbot-firstboot.service 2>/dev/null || true
rm -f /.firstboot_clawbot

# Reboot
reboot

exit 0
