#!/usr/bin/env bash
#### OpenClaw install module
####
#### https://github.com/openclaw/openclaw
#### This File is distributed under GPLv3
####

# shellcheck enable=require-variable-braces
set -Ee

# shellcheck disable=SC1091
source /common.sh
install_cleanup_trap

echo_green "Installing OpenClaw ..."

## Step 1: Install dependencies
apt-get update --allow-releaseinfo-change
# shellcheck disable=SC2086
check_install_pkgs ${OPENCLAW_DEPS}
## END Step 1

## Step 2: Install Node.js 22 via NodeSource
echo_green "Installing Node.js ${OPENCLAW_NODE_VERSION} ..."
curl -fsSL "https://deb.nodesource.com/setup_${OPENCLAW_NODE_VERSION}.x" | bash -
apt-get install -y nodejs
## END Step 2

## Step 3: Verify node version
echo_green "Node.js version: $(node --version)"
echo_green "npm version: $(npm --version)"
## END Step 3

## Step 4: Install OpenClaw globally
echo_green "Installing OpenClaw via npm ..."
npm install -g openclaw@latest
## END Step 4

## Step 5: Create config directory
pushd "/home/${BASE_USER}" &> /dev/null || exit 1
mkdir -p "/home/${BASE_USER}/.openclaw"
## END Step 5

## Step 6: Install config template and systemd service
echo_green "Installing OpenClaw configuration and service ..."
unpack /filesystem/root /
unpack /filesystem/home /home
## END Step 6

## Step 7: Set ownership
chown -R "${BASE_USER}:${BASE_USER}" "/home/${BASE_USER}/.openclaw"
## END Step 7

## Step 8: DISABLE openclaw by default (PicoClaw is the default agent)
echo_green "Disabling openclaw.service (PicoClaw is default) ..."
systemctl_if_exists disable openclaw.service || true
## END Step 8

popd &> /dev/null || exit 1

echo_green "Installing OpenClaw ... DONE! (disabled by default, use 'clawbot-switch-agent openclaw' to enable)"
